{
  "name": "terminal",
  "description": "终端命令执行技能，在终端中执行shell命令行指令",
  "version": "1.0.0",
  "type": "shell",
  "command": "terminal_cli.sh",
  "parameters": {
    "command": {
      "type": "string",
      "description": "要执行的命令",
      "required": true
    },
    "timeout": {
      "type": "number",
      "description": "超时时间（秒），默认30秒",
      "required": false
    }
  },
  "timeout": 30
}