{
  "name": "read_file",
  "description": "文件读取技能，从文件中读取内容",
  "version": "1.0.0",
  "type": "shell",
  "command": "read_file_cli.sh",
  "parameters": {
    "path": {
      "type": "string",
      "description": "目标文件路径（绝对路径或相对路径）",
      "required": true
    },
    "encoding": {
      "type": "string",
      "description": "文件编码，默认为 utf-8",
      "required": false
    }
  },
  "timeout": 30
}