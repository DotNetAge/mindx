{
  "name": "voice",
  "description": "语音播报技能，使用系统语音朗读文本内容",
  "version": "1.0.0",
  "type": "shell",
  "command": "voice_cli.sh",
  "parameters": {
    "text": {
      "type": "string",
      "description": "要播报的文本内容",
      "required": true
    },
    "voice": {
      "type": "string",
      "description": "语音类型",
      "required": false
    }
  },
  "timeout": 30
}