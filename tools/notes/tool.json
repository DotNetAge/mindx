{
  "name": "notes",
  "description": "笔记管理技能，创建、列出、打开笔记，管理备忘录",
  "version": "1.0.0",
  "type": "shell",
  "command": "notes_cli.sh",
  "parameters": {
    "action": {
      "type": "string",
      "description": "操作类型：\"create\"创建笔记、\"list\"列出笔记、\"open\"打开笔记",
      "required": true
    },
    "title": {
      "type": "string",
      "description": "笔记标题（create/open时必需）",
      "required": false
    },
    "content": {
      "type": "string",
      "description": "笔记内容（创建时使用）",
      "required": false
    }
  },
  "timeout": 30
}