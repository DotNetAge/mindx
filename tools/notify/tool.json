{
  "name": "notify",
  "description": "系统通知技能，显示macOS系统通知和提醒",
  "version": "1.0.0",
  "type": "shell",
  "command": "notify_cli.sh",
  "parameters": {
    "title": {
      "type": "string",
      "description": "通知标题，默认\"Notification\"",
      "required": false
    },
    "message": {
      "type": "string",
      "description": "通知消息内容",
      "required": true
    },
    "sound": {
      "type": "string",
      "description": "提示音名称",
      "required": false
    }
  },
  "timeout": 30
}