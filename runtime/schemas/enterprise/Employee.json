{
  "type": "object",
  "description": "组织内的员工、同事或利益相关者",
  "properties": {
    "name": { "type": "string", "description": "员工全名" },
    "title": {
      "type": "string",
      "description": "职位或岗位（如软件工程师、销售副总裁）"
    },
    "department": {
      "type": "string",
      "description": "员工所属的部门或团队"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "员工邮箱地址"
    },
    "role": {
      "type": "string",
      "description": "角色类别或职能（如个人贡献者、经理、高管）"
    },
    "manager": {
      "type": "string",
      "description": "员工汇报对象的经理或主管姓名"
    }
  },
  "required": ["name", "email"]
}
