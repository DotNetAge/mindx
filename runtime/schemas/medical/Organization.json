{
  "type": "object",
  "description": "医疗机构：医院、监管机构、非政府组织或研究机构",
  "properties": {
    "name": { "type": "string", "description": "Organization name" },
    "org_type": {
      "type": "string",
      "enum": ["hospital", "regulator", "NGO", "research"],
      "description": "Category of healthcare organization"
    },
    "location": {
      "type": "string",
      "description": "Geographic location or headquarters"
    },
    "specialties": {
      "type": "array",
      "items": { "type": "string" },
      "description": "医学专科或重点领域"
    },
    "size": {
      "type": "string",
      "description": "大致规模或容量（如床位数、员工数）"
    }
  },
  "required": ["name"]
}
