{
  "type": "object",
  "description": "医疗机构：医院、监管机构、非政府组织或研究机构",
  "properties": {
    "name": { "type": "string", "description": "医疗机构名称或缩写" },
    "org_type": {
      "type": "string",
      "enum": ["医院", "监管机构", "NGO", "研究机构"],
      "description": "医疗机构类别"
    },
    "location": {
      "type": "string",
      "description": "医疗机构的地理位置或总部位置"
    },
    "specialties": {
      "type": "array",
      "items": { "type": "string" },
      "description": "医学专科或重点领域"
    },
    "size": {
      "type": "string",
      "description": "大致规模或容量（如床位数、员工数）"
    }
  },
  "required": ["name"]
}
