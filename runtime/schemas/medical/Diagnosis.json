{
  "type": "object",
  "description": "诊断标准、检测或生物标志物",
  "properties": {
    "name": {
      "type": "string",
      "description": "诊断方法或检测名称"
    },
    "diagnosis_type": {
      "type": "string",
      "enum": ["标准", "检测", "生物标志物", "影像"],
      "description": "诊断方法类别"
    },
    "description": {
      "type": "string",
      "description": "诊断方法的详细描述"
    },
    "conditions_diagnosed": {
      "type": "array",
      "items": { "type": "string" },
      "description": "此方法帮助诊断的条件"
    },
    "accuracy": {
      "type": "string",
      "description": "典型的准确性、敏感性或特异性"
    }
  },
  "required": ["name"]
}
