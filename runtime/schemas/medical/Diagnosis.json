{
  "type": "object",
  "description": "诊断标准、检测或生物标志物",
  "properties": {
    "name": {
      "type": "string",
      "description": "诊断方法或检测名称"
    },
    "diagnosis_type": {
      "type": "string",
      "enum": ["criteria", "test", "biomarker", "imaging"],
      "description": "诊断方法类别"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the diagnostic method"
    },
    "conditions_diagnosed": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Conditions this method helps diagnose"
    },
    "accuracy": {
      "type": "string",
      "description": "典型的准确性、敏感性或特异性"
    }
  },
  "required": ["name"]
}
