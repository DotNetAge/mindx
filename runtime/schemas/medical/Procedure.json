{
  "type": "object",
  "description": "医疗程序、手术或检查",
  "properties": {
    "name": { "type": "string", "description": "程序或手术名称" },
    "procedure_type": {
      "type": "string",
      "enum": ["手术", "检查", "诊断"],
      "description": "程序类别"
    },
    "description": {
      "type": "string",
      "description": "程序的详细描述"
    },
    "duration": {
      "type": "string",
      "description": "程序的典型持续时间"
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" },
      "description": "程序相关的风险或并发症"
    },
    "recovery_time": {
      "type": "string",
      "description": "程序后的典型恢复时间"
    }
  },
  "required": ["name"]
}
