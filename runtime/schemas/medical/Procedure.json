{
  "type": "object",
  "description": "Medical procedure, surgery, or examination",
  "properties": {
    "name": { "type": "string", "description": "Procedure or surgery name" },
    "procedure_type": {
      "type": "string",
      "enum": ["surgery", "examination", "diagnostic"],
      "description": "程序类别"
    },
    "description": {
      "type": "string",
      "description": "程序的详细描述"
    },
    "duration": {
      "type": "string",
      "description": "程序的典型持续时间"
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Associated risks or complications"
    },
    "recovery_time": {
      "type": "string",
      "description": "程序后的典型恢复时间"
    }
  },
  "required": ["name"]
}
