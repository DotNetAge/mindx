{
  "type": "object",
  "description": "体征、症状或临床表现",
  "properties": {
    "name": { "type": "string", "description": "症状或体征名称" },
    "description": {
      "type": "string",
      "description": "症状的详细描述"
    },
    "associated_diseases": {
      "type": "array",
      "items": { "type": "string" },
      "description": "与此症状常见相关的疾病"
    },
    "severity_range": {
      "type": "string",
      "description": "典型严重范围（如轻微到严重）"
    },
    "duration": {
      "type": "string",
      "description": "症状的典型持续时间"
    },
    "body_system": {
      "type": "string",
      "description": "相关身体系统（如心血管、呼吸系统）"
    }
  },
  "required": ["name"]
}
