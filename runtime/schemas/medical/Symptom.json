{
  "type": "object",
  "description": "体征、症状或临床表现",
  "properties": {
    "name": { "type": "string", "description": "Symptom or sign name" },
    "description": {
      "type": "string",
      "description": "Detailed description of the symptom"
    },
    "associated_diseases": {
      "type": "array",
      "items": { "type": "string" },
      "description": "与此症状常见相关的疾病"
    },
    "severity_range": {
      "type": "string",
      "description": "Typical severity range (e.g., mild to severe)"
    },
    "duration": {
      "type": "string",
      "description": "Typical duration of the symptom"
    },
    "body_system": {
      "type": "string",
      "description": "相关身体系统（如心血管、呼吸系统）"
    }
  },
  "required": ["name"]
}
