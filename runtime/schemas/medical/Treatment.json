{
  "type": "object",
  "description": "Treatment, therapy, regimen, or medication class",
  "properties": {
    "name": { "type": "string", "description": "Treatment or therapy name" },
    "treatment_type": {
      "type": "string",
      "enum": ["therapy", "medication", "surgery", "lifestyle"],
      "description": "Category of treatment"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the treatment"
    },
    "indications": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Conditions or symptoms the treatment addresses"
    },
    "side_effects": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Possible side effects"
    },
    "duration": {
      "type": "string",
      "description": "Typical treatment duration"
    }
  },
  "required": ["name"]
}
