{
  "type": "object",
  "description": "治疗、疗法、方案或药物类别",
  "properties": {
    "name": { "type": "string", "description": "治疗或疗法名称" },
    "treatment_type": {
      "type": "string",
      "enum": ["疗法", "药物", "手术", "生活方式"],
      "description": "治疗类别"
    },
    "description": {
      "type": "string",
      "description": "治疗的详细描述"
    },
    "indications": {
      "type": "array",
      "items": { "type": "string" },
      "description": "治疗针对的条件或症状"
    },
    "side_effects": {
      "type": "array",
      "items": { "type": "string" },
      "description": "可能的副作用"
    },
    "duration": {
      "type": "string",
      "description": "典型的治疗周期"
    }
  },
  "required": ["name"]
}
