{
  "type": "object",
  "description": "治疗、疗法、方案或药物类别",
  "properties": {
    "name": { "type": "string", "description": "治疗或疗法名称" },
    "treatment_type": {
      "type": "string",
      "enum": ["therapy", "medication", "surgery", "lifestyle"],
      "description": "Category of treatment"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the treatment"
    },
    "indications": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Conditions or symptoms the treatment addresses"
    },
    "side_effects": {
      "type": "array",
      "items": { "type": "string" },
      "description": "可能的副作用"
    },
    "duration": {
      "type": "string",
      "description": "典型的治疗周期"
    }
  },
  "required": ["name"]
}
