{
  "type": "object",
  "description": "Prevention method, vaccine, or lifestyle measure",
  "properties": {
    "name": {
      "type": "string",
      "description": "Prevention method or measure name"
    },
    "prevention_type": {
      "type": "string",
      "enum": ["vaccine", "lifestyle", "screening", "education"],
      "description": "Category of prevention method"
    },
    "description": {
      "type": "string",
      "description": "预防方法的详细描述"
    },
    "target_conditions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "此方法旨在预防的疾病"
    },
    "effectiveness": {
      "type": "string",
      "description": "预防方法的有效性或功效"
    }
  },
  "required": ["name"]
}
