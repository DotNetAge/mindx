{
  "type": "object",
  "description": "预防方法、疫苗或生活方式措施",
  "properties": {
    "name": {
      "type": "string",
      "description": "预防方法或措施名称"
    },
    "prevention_type": {
      "type": "string",
      "enum": ["疫苗", "生活方式", "筛查", "教育"],
      "description": "预防方法类别"
    },
    "description": {
      "type": "string",
      "description": "预防方法的详细描述"
    },
    "target_conditions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "此方法旨在预防的疾病"
    },
    "effectiveness": {
      "type": "string",
      "description": "预防方法的有效性或功效"
    }
  },
  "required": ["name"]
}
