{
  "type": "object",
  "description": "表示特定方法、流程、技术、公式或框架的独立知识点",
  "properties": {
    "name": { "type": "string", "description": "知识点的名称" },
    "type": {
      "type": "string",
      "enum": ["方法", "流程", "技术", "公式", "框架"],
      "description": "知识点的类别"
    },
    "description": {
      "type": "string",
      "description": "对该知识点包含的内容及其使用方式的详细说明"
    },
    "prerequisites": {
      "type": "array",
      "items": { "type": "string" },
      "description": "理解或应用该知识点所需的先决知识或技能"
    },
    "applications": {
      "type": "array",
      "items": { "type": "string" },
      "description": "该知识点被应用的常见用例或场景"
    }
  },
  "required": ["name", "type", "description"]
}
