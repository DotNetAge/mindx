{
  "type": "object",
  "description": "市场趋势、规律或方向性变化",
  "properties": {
    "name": { "type": "string", "description": "趋势名称" },
    "direction": {
      "type": "string",
      "description": "趋势方向：上升、稳定或下降"
    },
    "category": {
      "type": "string",
      "description": "趋势类别：技术、社会或经济"
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string" },
      "description": "支撑该趋势的证据"
    },
    "impact_level": {
      "type": "string",
      "description": "影响程度（如高、中、低）"
    }
  },
  "required": ["name"]
}
