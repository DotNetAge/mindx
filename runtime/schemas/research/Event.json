{
  "type": "object",
  "description": "商业事件：融资、发布、政策变更、并购等",
  "properties": {
    "name": { "type": "string", "description": "事件名称" },
    "event_type": {
      "type": "string",
      "description": "事件类型：融资、发布、政策或并购"
    },
    "date": { "type": "string", "description": "事件日期" },
    "participants": {
      "type": "array",
      "items": { "type": "string" },
      "description": "主要参与方或相关方"
    },
    "financial_details": {
      "type": "string",
      "description": "相关财务细节（如适用）"
    },
    "impact": {
      "type": "string",
      "description": "事件对业务的影响"
    }
  },
  "required": ["name"]
}
