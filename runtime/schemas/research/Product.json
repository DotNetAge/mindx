{
  "type": "object",
  "description": "产品、服务、解决方案或功能",
  "properties": {
    "name": { "type": "string", "description": "产品名称" },
    "category": { "type": "string", "description": "产品类别" },
    "pricing": { "type": "string", "description": "定价模式" },
    "description": { "type": "string", "description": "产品描述" },
    "stage": {
      "type": "string",
      "enum": ["开发", "上市", "成熟", "衰退"],
      "description": "产品生命周期阶段"
    },
    "competitors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "竞争产品"
    }
  },
  "required": ["name"]
}
