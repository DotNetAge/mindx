{
  "type": "object",
  "description": "新闻中出现的人物或实体",
  "properties": {
    "name": {
      "type": "string",
      "description": "人物的全名"
    },
    "role": {
      "type": "string",
      "description": "人物在新闻中的主要角色或功能",
      "enum": ["政治人物", "名人", "见证", "专家", "发言人", "活动家", "官方"]
    },
    "affiliation": {
      "type": "string",
      "description": "该人物所属的组织、政党或团体"
    },
    "relevance": {
      "type": "string",
      "description": "该人物与当前新闻背景的相关性"
    },
    "statements": {
      "type": "array",
      "description": "报道中归属于该人物的关键声明或引述",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["name", "role"]
}
