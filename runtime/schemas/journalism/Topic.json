{
  "type": "object",
  "description": "新闻主题、议题或报道领域（如外交、经济、科技）",
  "properties": {
    "name": {
      "type": "string",
      "description": "新闻主题或报道领域的名称"
    },
    "topic_type": {
      "type": "string",
      "description": "主题的类别",
      "enum": [
        "diplomacy",
        "economy",
        "tech",
        "science",
        "society",
        "politics",
        "environment",
        "culture",
        "sports"
      ]
    },
    "description": {
      "type": "string",
      "description": "该主题涵盖内容的简要描述"
    },
    "sub_topics": {
      "type": "array",
      "description": "该主题内的相关子主题或具体领域",
      "items": {
        "type": "string"
      }
    },
    "trending": {
      "type": "boolean",
      "description": "指示该主题当前是否在新闻周期中热门"
    }
  },
  "required": ["name", "topic_type"]
}
