{
  "type": "object",
  "description": "参与新闻报道的组织、政府机构、非政府组织或公司",
  "properties": {
    "name": {
      "type": "string",
      "description": "组织的全称"
    },
    "org_type": {
      "type": "string",
      "description": "组织的类型",
      "enum": [
        "government",
        "NGO",
        "company",
        "international",
        "educational",
        "media",
        "military"
      ]
    },
    "sector": {
      "type": "string",
      "description": "该组织运营所在的行业或领域"
    },
    "headquarters": {
      "type": "string",
      "description": "该组织总部所在地"
    },
    "leadership": {
      "type": "string",
      "description": "该组织的主要领导者或代表"
    }
  },
  "required": ["name", "org_type"]
}
