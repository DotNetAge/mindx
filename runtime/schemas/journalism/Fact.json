{
  "type": "object",
  "description": "新闻报道中使用的已核实事实、数据点或统计数据",
  "properties": {
    "statement": {
      "type": "string",
      "description": "事实性陈述或数据点"
    },
    "category": {
      "type": "string",
      "description": "事实信息的类型",
      "enum": ["数据", "统计", "已核实信息", "历史", "法律"]
    },
    "source": {
      "type": "string",
      "description": "提供该事实的原始来源或权威机构"
    },
    "date_verified": {
      "type": "string",
      "description": "该事实最后一次核实的日期（优先使用 ISO 8601 格式）"
    },
    "methodology": {
      "type": "string",
      "description": "获取或核实该事实所使用的方法（如适用）"
    },
    "related_claims": {
      "type": "array",
      "description": "与该事实相关的声明引用",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["statement", "category"]
}
