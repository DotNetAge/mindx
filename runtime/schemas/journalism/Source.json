{
  "type": "object",
  "description": "新闻来源、新闻机构或媒体机构",
  "properties": {
    "name": {
      "type": "string",
      "description": "来源的名称"
    },
    "source_type": {
      "type": "string",
      "description": "来源的类型",
      "enum": ["新闻机构", "媒体", "博客", "社交媒体", "官方声明"]
    },
    "region": {
      "type": "string",
      "description": "来源主要运营或报道的地理区域或国家"
    },
    "reliability_rating": {
      "type": "string",
      "description": "来源的可靠性评估",
      "enum": ["高", "中等", "低", "未验证"]
    },
    "url": {
      "type": "string",
      "description": "来源的主要网站或 URL"
    },
    "political_lean": {
      "type": "string",
      "description": "来源声明或观察到的政治倾向（如有）"
    }
  },
  "required": ["name", "source_type"]
}
