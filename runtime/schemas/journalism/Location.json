{
  "type": "object",
  "description": "新闻中出现的地理地点、区域或国家",
  "properties": {
    "name": {
      "type": "string",
      "description": "地点的名称"
    },
    "location_type": {
      "type": "string",
      "description": "地理实体的类型",
      "enum": ["国家", "区域", "城市", "地点", "区县", "地标"]
    },
    "coordinates": {
      "type": "object",
      "description": "该地点的地理坐标",
      "properties": {
        "latitude": { "type": "number" },
        "longitude": { "type": "number" }
      }
    },
    "significance": {
      "type": "string",
      "description": "该地点在当前新闻背景中的重要性"
    },
    "related_events": {
      "type": "array",
      "description": "与该地点相关的事件名称或引用",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["name", "location_type"]
}
