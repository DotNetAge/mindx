{
  "type": "object",
  "description": "A geographic location, region, or country relevant to news coverage",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the location (country, region, city, or site)"
    },
    "location_type": {
      "type": "string",
      "description": "The type of geographic entity",
      "enum": ["country", "region", "city", "site", "district", "landmark"]
    },
    "coordinates": {
      "type": "object",
      "description": "该地点的地理坐标",
      "properties": {
        "latitude": { "type": "number" },
        "longitude": { "type": "number" }
      }
    },
    "significance": {
      "type": "string",
      "description": "该地点在当前新闻背景中的重要性"
    },
    "related_events": {
      "type": "array",
      "description": "与该地点相关的事件名称或引用",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["name", "location_type"]
}
