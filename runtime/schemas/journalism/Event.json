{
  "type": "object",
  "description": "新闻中出现的事件、事故或发展",
  "properties": {
    "name": {
      "type": "string",
      "description": "事件的名称或标题（如新闻会议、选举、自然灾害等）"
    },
    "event_type": {
      "type": "string",
      "description": "事件的性质",
      "enum": [
        "事故",
        "发展",
        "公告",
        "会议",
        "选举",
        "自然灾害",
        "抗议",
        "仪式"
      ]
    },
    "date": {
      "type": "string",
      "description": "事件发生的日期或日期范围（ISO 8601 格式优先）"
    },
    "location": {
      "type": "string",
      "description": "事件发生的地理位置"
    },
    "participants": {
      "type": "array",
      "description": "参与该事件的关键人物、组织或实体",
      "items": {
        "type": "string"
      }
    },
    "significance": {
      "type": "string",
      "description": "事件的重要性或影响等级",
      "enum": ["重大", "主要", "次要", "背景"]
    }
  },
  "required": ["name", "event_type"]
}
