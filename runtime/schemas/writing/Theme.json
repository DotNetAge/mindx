{
  "type": "object",
  "description": "文学作品中探讨的核心主题、母题或潜在思想。",
  "properties": {
    "name": {
      "type": "string",
      "description": "主题名称，如爱、自由、科技与人、成长"
    },
    "description": {
      "type": "string",
      "description": "主题的详细解释"
    },
    "related_themes": {
      "type": "array",
      "description": "相关主题",
      "items": {
        "type": "string"
      }
    },
    "works": {
      "type": "array",
      "description": "突出体现该主题的示例作品",
      "items": {
        "type": "string"
      }
    },
    "significance": {
      "type": "string",
      "description": "该母题的主题重要性或文化相关性"
    }
  },
  "required": ["name"]
}
