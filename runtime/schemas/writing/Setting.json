{
  "type": "object",
  "description": "文学作品的背景设置，涵盖时间、地点、社会和整体世界观。",
  "properties": {
    "name": {
      "type": "string",
      "description": "设置的标签或简短标识符"
    },
    "setting_type": {
      "type": "string",
      "description": "设置的主要领域",
      "enum": ["时间", "地点", "社会", "世界观"]
    },
    "description": {
      "type": "string",
      "description": "设置的详细描述"
    },
    "time_period": {
      "type": "string",
      "description": "故事发生的历史时代、季节或时间框架"
    },
    "location": {
      "type": "string",
      "description": "叙事的地理或空间背景"
    },
    "mood": {
      "type": "string",
      "description": "设置的情感氛围或环境"
    }
  },
  "required": ["name"]
}
