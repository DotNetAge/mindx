{
  "type": "object",
  "description": "文学作品的叙事风格，包括视角、语气、风格特征等。",
  "properties": {
    "name": {
      "type": "string",
      "description": "写作风格的名称"
    },
    "perspective": {
      "type": "string",
      "description": "故事讲述的视角",
      "enum": ["第一人称", "第三人称", "全知"]
    },
    "voice_tone": {
      "type": "string",
      "description": "叙事的语气或情感"
    },
    "stylistic_markers": {
      "type": "array",
      "description": "反复出现的风格特征，如句子节奏、措辞、修辞语言模式",
      "items": {
        "type": "string"
      }
    },
    "influences": {
      "type": "string",
      "description": "塑造该写作风格的文学或文化影响"
    }
  },
  "required": ["name"]
}
