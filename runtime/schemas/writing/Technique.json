{
  "type": "object",
  "description": "文学作品中使用的具体艺术技巧或修辞语言模式。",
  "properties": {
    "name": {
      "type": "string",
      "description": "写作技巧, 例如：隐喻, 伏笔, 对话, 倒叙"
    },
    "technique_type": {
      "type": "string",
      "description": "写作技巧的类别",
      "enum": ["隐喻", "伏笔", "对话", "倒叙"]
    },
    "description": {
      "type": "string",
      "description": "写作技巧的详细解释"
    },
    "effect": {
      "type": "string",
      "description": "该技巧所产生的艺术或修辞效果"
    },
    "example_usage": {
      "type": "string",
      "description": "说明该技巧在实际中如何应用的具体示例"
    }
  },
  "required": ["name"]
}
