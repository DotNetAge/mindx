{
  "type": "object",
  "description": "文学作品的叙事结构，组织故事的顺序和节奏。",
  "properties": {
    "name": {
      "type": "string",
      "description": "结构模式的名称"
    },
    "structure_type": {
      "type": "string",
      "description": "结构模式的标准化标签",
      "enum": ["三幕式", "起承转合", "非线性"]
    },
    "parts": {
      "type": "array",
      "description": "结构模式的组成部分",
      "items": {
        "type": "string"
      }
    },
    "purpose": {
      "type": "string",
      "description": "结构模式的功能"
    },
    "example_works": {
      "type": "array",
      "description": "体现该叙事结构的著名作品",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["name"]
}
