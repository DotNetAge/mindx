{
  "type": "object",
  "description": "文学作品中的创作作品，如小说、诗、剧本或故事。",
  "properties": {
    "title": {
      "type": "string",
      "description": "作品的标题名称"
    },
    "author": {
      "type": "string",
      "description": "创作该作品的作者姓名"
    },
    "work_type": {
      "type": "string",
      "description": "作品的文学形式",
      "enum": ["小说", "诗", "剧本", "故事"]
    },
    "genre": {
      "type": "string",
      "description": "作品的文学类型"
    },
    "publication_date": {
      "type": "string",
      "description": "作品首次出版的日期或年份"
    },
    "synopsis": {
      "type": "string",
      "description": "作品的简要概述"
    },
    "characters": {
      "type": "array",
      "description": "作品中出现的主要角色",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["title"]
}
