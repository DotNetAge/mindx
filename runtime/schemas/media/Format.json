{
  "type": "object",
  "description": "媒体格式，描述视频、文本、音频或直播格式等",
  "properties": {
    "name": {
      "type": "string",
      "description": "内容格式名称，例如：短视频、图文、直播、播客、长视频"
    },
    "format_type": {
      "type": "string",
      "enum": [
        "short_video",
        "long_video",
        "live",
        "audio",
        "text",
        "image_text"
      ],
      "description": "格式的技术类别"
    },
    "typical_duration": {
      "type": "string",
      "description": "格式典型时长或长度，例如：15-60秒、5-15分钟、N/A"
    },
    "platform": {
      "type": "string",
      "description": "该格式通常关联的平台，例如：抖音、B站、小红书"
    }
  },
  "required": ["name"]
}
