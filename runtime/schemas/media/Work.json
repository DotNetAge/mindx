{
  "type": "object",
  "description": "在媒体平台上创作并发布的已发布内容，例如视频、文章或帖子"
  "properties": {
    "title": {
      "type": "string",
      "description": "Title of the content piece"
    },
    "creator": {
      "type": "string",
      "description": "Name or handle of the creator who published this work"
    },
    "platform": {
      "type": "string",
      "description": "作品发布的平台"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Link to the published work"
    },
    "publish_date": {
      "type": "string",
      "format": "date",
      "description": "Date when the work was published, in YYYY-MM-DD format"
    },
    "format": {
      "type": "string",
      "description": "Content format of this work, e.g. 短视频, 图文, 播客"
    },
    "performance_metrics": {
      "type": "object",
      "description": "Key performance indicators for this work",
      "properties": {
        "views": { "type": "integer", "description": "观看/播放次数" },
        "likes": { "type": "integer", "description": "点赞数" },
        "shares": {
          "type": "integer",
          "description": "Number of shares/retweets"
        },
        "comments": { "type": "integer", "description": "评论数" }
      },
      "additionalProperties": true
    }
  },
  "required": ["title"]
}
