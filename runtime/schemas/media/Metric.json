{
  "type": "object",
  "description": "媒体平台上的绩效指标 — 播放量、点赞数、转化率、粉丝数等",
  "properties": {
    "name": {
      "type": "string",
      "description": "指标名称，例如：播放量、点赞数、转化率、粉丝数"
    },
    "metric_type": {
      "type": "string",
      "enum": [
        "播放量",
        "点赞数",
        "转化率",
        "粉丝数",
        "分享数",
        "评论数",
        "点击数",
        "广告收入",
        "广告成本"
      ],
      "description": "指标类别，例如：播放量、点赞数、转化率、粉丝数"
    },
    "value": {
      "type": "number",
      "description": "指标的数值"
    },
    "unit": {
      "type": "string",
      "description": "计量单位，例如：万、亿、%、次"
    },
    "platform": {
      "type": "string",
      "description": "该指标的数据来源平台"
    },
    "period": {
      "type": "string",
      "description": "指标覆盖的时间周期，例如：2024-Q1、2024年、过去30天"
    }
  },
  "required": ["name"]
}
