{
  "type": "object",
  "description": "金融中的风险因素 — 波动率、信用风险、通胀风险、流动性风险、市场风险",
  "properties": {
    "name": { "type": "string", "description": "风险因素名称" },
    "risk_type": {
      "type": "string",
      "enum": ["波动率", "信用风险", "通胀风险", "流动性风险", "市场风险"],
      "description": "风险类别"
    },
    "description": {
      "type": "string",
      "description": "风险因素及其影响的说明"
    },
    "severity": {
      "type": "string",
      "enum": ["低", "中", "高", "严重"],
      "description": "风险严重程度"
    },
    "mitigation_methods": {
      "type": "array",
      "items": { "type": "string" },
      "description": "缓解此风险的常用方法"
    }
  },
  "required": ["name", "risk_type"]
}
