{
  "type": "object",
  "description": "金融界关键人物 — 分析师、经济学家、基金经理、交易员、行业专家",
  "properties": {
    "name": { "type": "string", "description": "人物全名" },
    "role": {
      "type": "string",
      "enum": ["analyst", "economist", "manager", "trader"],
      "description": "职业角色"
    },
    "organization": {
      "type": "string",
      "description": "所属机构或雇主"
    },
    "specializations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "专业领域或专长"
    },
    "reputation": {
      "type": "string",
      "description": "市场声誉或影响力等级（如知名、受尊敬、有争议）"
    }
  },
  "required": ["name", "role"]
}
