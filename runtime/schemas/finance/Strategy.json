{
  "type": "object",
  "description": "投资或交易策略 — 定期定额投资、对冲、价值投资、动量交易"
  "properties": {
    "name": { "type": "string", "description": "策略名称" },
    "strategy_type": {
      "type": "string",
      "enum": ["investment", "trading", "hedging"],
      "description": "策略类别"
    },
    "description": {
      "type": "string",
      "description": "策略方法的详细说明"
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "相关风险等级"
    },
    "time_horizon": {
      "type": "string",
      "description": "典型持有期限（如短期、中期、长期）"
    },
    "asset_classes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "策略适用的资产类别"
    }
  },
  "required": ["name", "strategy_type"]
}
