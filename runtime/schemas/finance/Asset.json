{
  "type": "object",
  "description": "金融资产 — 股票、债券、房地产、大宗商品、加密货币",
  "properties": {
    "name": { "type": "string", "description": "资产名称" },
    "type": {
      "type": "string",
      "enum": ["stock", "bond", "real_estate", "commodity", "crypto", "other"],
      "description": "资产类别"
    },
    "ticker": {
      "type": "string",
      "description": "交易代码（如适用）"
    },
    "value": { "type": "number", "description": "当前价值或价格" },
    "currency": {
      "type": "string",
      "description": "货币单位（如 USD、CNY、EUR）"
    },
    "market": {
      "type": "string",
      "description": "资产交易所在的市场或交易所（如 NYSE、SSE、HKEX）"
    }
  },
  "required": ["name", "type"]
}
