{
  "type": "object",
  "description": "绩效指标 — 收益率、夏普比率、ROI、波动率、阿尔法、贝塔",
  "properties": {
    "name": { "type": "string", "description": "指标名称" },
    "metric_type": {
      "type": "string",
      "enum": ["收益率", "夏普比率", "波动率", "ROI", "阿尔法", "贝塔"],
      "description": "指标类别"
    },
    "value": { "type": "number", "description": "指标的数值" },
    "benchmark": {
      "type": "string",
      "description": "用于比较的基准（如适用）"
    },
    "period": {
      "type": "string",
      "description": "指标计算的时间周期（如 1Y、YTD、3M）"
    },
    "interpretation": {
      "type": "string",
      "description": "指标值的简要解读或意义"
    }
  },
  "required": ["name", "metric_type"]
}
