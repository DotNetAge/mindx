{
  "type": "object",
  "description": "监管机构、政策或法规 — SEC、央行政策、货币政策规则、巴塞尔协议",
  "properties": {
    "name": { "type": "string", "description": "法规或政策名称" },
    "regulatory_body": {
      "type": "string",
      "description": "执行机构或监管部门"
    },
    "jurisdiction": {
      "type": "string",
      "description": "法规适用的地理或法律管辖区"
    },
    "effective_date": {
      "type": "string",
      "description": "法规生效日期"
    },
    "description": {
      "type": "string",
      "description": "法规内容及其目的的概述"
    },
    "affected_sectors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "受此法规影响的金融部门或行业"
    }
  },
  "required": ["name", "regulatory_body"]
}
