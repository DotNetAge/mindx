{
  "type": "object",
  "description": "金融市场或交易所 — 证券交易所、债券市场、商品市场、外汇市场、衍生品市场"
  "properties": {
    "name": { "type": "string", "description": "市场或交易所名称" },
    "market_type": {
      "type": "string",
      "enum": ["stock", "bond", "commodity", "derivative", "forex"],
      "description": "金融市场类型"
    },
    "region": {
      "type": "string",
      "description": "市场所在的地理区域或国家"
    },
    "operating_hours": {
      "type": "string",
      "description": "交易时间和时区（如 9:30-16:00 ET）"
    },
    "index_tickers": {
      "type": "array",
      "items": { "type": "string" },
      "description": "与该市场相关的主要基准指数代码"
    }
  },
  "required": ["name", "market_type"]
}
