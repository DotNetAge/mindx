{
  "type": "object",
  "description": "经济或技术指标 — K线、市盈率、GDP、CPI、移动平均线、RSI",
  "properties": {
    "name": { "type": "string", "description": "指标名称" },
    "indicator_type": {
      "type": "string",
      "enum": ["economic", "technical", "fundamental"],
      "description": "指标类别"
    },
    "value": {
      "type": "number",
      "description": "指标的当前数值"
    },
    "unit": {
      "type": "string",
      "description": "计量单位（如 %、点、USD、比率）"
    },
    "frequency": {
      "type": "string",
      "description": "发布频率（如每日、每周、每月、每季度、每年）"
    },
    "source": {
      "type": "string",
      "description": "指标的数据来源或发布机构"
    }
  },
  "required": ["name", "indicator_type"]
}
