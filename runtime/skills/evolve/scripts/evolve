#!/usr/bin/env python3
"""
Evolve helper — reads session data from MindX daemon via RPC.

Design:
  - All session data comes from daemon RPC (session.list, session.get).
    No direct filesystem access to session storage.
  - Default output is compact (context budget friendly).
  - LLM progressively drills down (outline -> expand).
  - All paths passed explicitly by LLM.

Usage:
  evolve list
  evolve get <session-id> [--msg N | --range M-N]
  evolve check <name> --skills-dir <path>
  evolve dedup --skills-dir <path>
"""

import argparse
import json
import os
import signal
import sys
import uuid
from datetime import datetime, timezone

try:
    import websocket
except ImportError:
    print("websocket-client library is required", file=sys.stderr)
    print("Install with: pip install websocket-client", file=sys.stderr)
    sys.exit(1)

PROG = os.path.basename(__file__)

# ---------------------------------------------------------------------------
# Signal safety
# ---------------------------------------------------------------------------

def _signal_handler(signum, frame):
    sys.stderr.write(f"\n[{PROG}] interrupted\n")
    sys.exit(130)

signal.signal(signal.SIGINT, _signal_handler)
signal.signal(signal.SIGTERM, _signal_handler)


# ---------------------------------------------------------------------------
# RPC client — inline, no external dependency
# ---------------------------------------------------------------------------

DEFAULT_HOST = "localhost"
DEFAULT_PORT = 1314
DEFAULT_PATH = "/ws"
TIMEOUT = 30


def rpc_call(method, params=None):
    host = os.environ.get("MINDX_WS_HOST", DEFAULT_HOST)
    port = int(os.environ.get("MINDX_WS_PORT", str(DEFAULT_PORT)))
    path = os.environ.get("MINDX_WS_PATH", DEFAULT_PATH)
    url = f"ws://{host}:{port}{path}"

    try:
        ws = websocket.create_connection(url, timeout=TIMEOUT)
    except Exception as e:
        print(f'{{"error": "connection failed: {e}"}}', file=sys.stderr)
        sys.exit(1)

    request_id = str(uuid.uuid4())
    request = {"jsonrpc": "2.0", "id": request_id, "method": method}
    if params is not None:
        request["params"] = params

    try:
        ws.send(json.dumps(request))
        response_str = ws.recv()
        ws.close()
    except Exception as e:
        ws.close()
        print(f'{{"error": "rpc call failed: {e}"}}', file=sys.stderr)
        sys.exit(1)

    try:
        response = json.loads(response_str)
    except json.JSONDecodeError:
        print(f'{{"error": "invalid JSON response"}}', file=sys.stderr)
        sys.exit(1)

    if "error" in response and response["error"] is not None:
        err = response["error"]
        msg = err.get("message", str(err))
        print(f'{{"error": "rpc error: {msg}"}}', file=sys.stderr)
        sys.exit(1)

    return response.get("result")


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def ts_fmt(ts_str):
    """Format ISO timestamp string to compact form."""
    if not ts_str:
        return ""
    try:
        if ts_str.endswith("Z"):
            ts_str = ts_str[:-1] + "+00:00"
        dt = datetime.fromisoformat(ts_str)
        return dt.strftime("%Y-%m-%d %H:%M")
    except (ValueError, TypeError):
        return ts_str[:16] if ts_str else ""


def truncate(text, max_len=120):
    s = text.replace("\n", " ").strip()
    if len(s) > max_len:
        s = s[: max_len - 3] + "..."
    return s


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------


def cmd_list():
    """List sessions retrieved from daemon via session.list RPC."""
    sessions = rpc_call("session.list") or []
    if not sessions:
        print("No sessions found.")
        return

    print(f"{'SESSION ID':<24} {'AGENT':<16} {'MSGS':<5}  {'LAST ACTIVE':<16}  TITLE")
    print("-" * 100)
    for s in sessions:
        sid = s.get("session_id", "?")
        agent = s.get("agent_name", "?")
        title = truncate(s.get("title", ""), 50)
        last_active = ts_fmt(s.get("last_activity_at", ""))
        # Messages field is populated only if explicitly requested (session.get),
        # not in session.list. Show "?" instead of a misleading 0.
        msgs = s.get("message_count", "?")  # only in meta, not always in list
        print(f"{sid:<24} {agent:<16} {str(msgs):<5}  {last_active:<16}  {title}")


def cmd_get(session_id, msg_num, msg_range):
    """Get session content from daemon via session.get RPC."""
    result = rpc_call("session.get", {"session_id": session_id})
    if not result:
        print(f"Session '{session_id}' not found.")
        sys.exit(1)

    messages = result.get("messages", [])
    meta = result.get("meta", {})

    if not messages:
        print(f"[empty session: {session_id}]")
        return

    total = len(messages)
    user_count = sum(1 for m in messages if m.get("role") == "user")
    asst_count = sum(1 for m in messages if m.get("role") == "assistant")

    # Determine subset of messages to display
    if msg_num is not None:
        idx = msg_num - 1
        if idx < 0 or idx >= total:
            print(f"Message #{msg_num} out of range (1-{total})")
            return
        subset = [(msg_num, messages[idx])]
        expand = True
    elif msg_range:
        parts = msg_range.split("-", 1)
        try:
            start = max(0, int(parts[0]) - 1)
            end = min(total, int(parts[1]) if len(parts) > 1 else total)
        except (ValueError, IndexError):
            print(f"Invalid range: {msg_range} — use M-N format")
            return
        if start >= end:
            print(f"Empty range: {msg_range}")
            return
        subset = [(i + 1, messages[i]) for i in range(start, end)]
        expand = True
    else:
        # Outline mode: show all messages in compact form
        subset = [(i + 1, messages[i]) for i in range(total)]
        expand = False

    if expand:
        # Full content mode
        aid = result.get("session_id", session_id)
        agent = meta.get("agent_name", "?")
        print(f"Session: {aid}  |  Agent: {agent}")
        print(f"Showing {len(subset)} of {total} messages")
        print("=" * 60)
        max_chars = 1500
        for num, msg in subset:
            role = msg.get("role", "?")
            content = msg.get("content", "")
            ts = msg.get("timestamp", 0)
            ts_str = datetime.fromtimestamp(ts / 1000, tz=timezone.utc).strftime("%H:%M:%S") if ts else ""

            if len(content) > max_chars:
                content = content[:max_chars] + f"\n[... truncated, {len(content)} chars total]"

            print(f"\n--- #{num} {role.upper()} [{ts_str}] ---")
            print(content)
    else:
        # Outline mode: compact one-liner
        title = meta.get("title", "")
        agent = meta.get("agent_name", "?")
        print(f"Session: {session_id}  |  Agent: {agent}")
        if title:
            print(f"Title: {truncate(title, 80)}")
        print(f"Messages: {total} ({user_count} user, {asst_count} assistant)")
        print()

        line_limit = 200
        for i, (num, msg) in enumerate(subset):
            if i >= line_limit:
                remaining = total - i
                print(f"... {remaining} more — use --range or --msg to drill down")
                break
            role = msg.get("role", "?")
            content = msg.get("content", "")
            ts = msg.get("timestamp", 0)
            ts_str = datetime.fromtimestamp(ts / 1000, tz=timezone.utc).strftime("%H:%M") if ts else ""
            preview = truncate(content)

            tool_tag = ""
            tcs = msg.get("tool_calls")
            if role == "assistant" and tcs and len(tcs) > 0:
                names = [tc.get("name", "?") for tc in tcs[:3]]
                tool_tag = f"[{','.join(names)}] "

            print(f"#{num:<3} {ts_str:<5} {role:<9} {tool_tag}{preview}")


def cmd_check(name, skills_dir):
    """Check if an evolved skill already exists."""
    evolved_dir = os.path.join(skills_dir, "evolved", name)
    exists = os.path.isdir(evolved_dir) and os.path.isfile(
        os.path.join(evolved_dir, "SKILL.md")
    )
    print(json.dumps({"name": name, "exists": exists, "path": evolved_dir}))


def cmd_dedup(skills_dir):
    """List all evolved skills (for dedup reference)."""
    evolved_dir = os.path.join(skills_dir, "evolved")
    if not os.path.isdir(evolved_dir):
        print("No evolved skills yet.")
        return

    skills = []
    for name in sorted(os.listdir(evolved_dir)):
        skill_path = os.path.join(evolved_dir, name, "SKILL.md")
        if not os.path.isfile(skill_path):
            continue
        with open(skill_path, "r") as f:
            content = f.read()
        desc = ""
        if content.startswith("---"):
            end = content.find("---", 3)
            if end > 0:
                for line in content[3:end].strip().split("\n"):
                    line = line.strip()
                    if line.startswith("description:"):
                        desc = line[len("description:"):].strip().strip("'\"")
                        break
        skills.append({"name": name, "description": desc})

    if skills:
        print(f"Evolved skills ({len(skills)}):")
        for s in skills:
            desc_short = s["description"][:80].replace("\n", " ")
            print(f"  {s['name']:<30} {desc_short}")
    else:
        print("No evolved skills yet.")


# ---------------------------------------------------------------------------
# CLI wiring
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        description="Evolve helper — reads session data from daemon via RPC"
    )
    sub = parser.add_subparsers(dest="command", required=True)

    p = sub.add_parser("list", help="List sessions from daemon")
    p = sub.add_parser("get", help="Get session content from daemon")
    p.add_argument("session_id", help="Session ID")
    p.add_argument("--msg", type=int, help="Show single message in full")
    p.add_argument("--range", metavar="M-N", help="Show message range in full")

    p = sub.add_parser("check", help="Check if evolved skill name is taken")
    p.add_argument("name", help="Skill name to check")
    p.add_argument("--skills-dir", required=True, help="Path to skills directory")

    p = sub.add_parser("dedup", help="List already-evolved skills")
    p.add_argument("--skills-dir", required=True, help="Path to skills directory")

    args = parser.parse_args()

    if args.command == "list":
        cmd_list()
    elif args.command == "get":
        cmd_get(args.session_id, args.msg, args.range)
    elif args.command == "check":
        cmd_check(args.name, args.skills_dir)
    elif args.command == "dedup":
        cmd_dedup(args.skills_dir)


if __name__ == "__main__":
    main()
